---
import Base from '../../layouts/Base.astro';
import CTA from '../../components/CTA.astro';
import { site } from '../../data/site';
import { serviceAreas } from '../../data/serviceAreas';

export function getStaticPaths() {
  return serviceAreas.map((area) => ({
    params: { slug: `ev-charger-installation-${area.slug}` },
    props: { area },
  }));
}

const { area } = Astro.props;
---

<Base
  title={`EV Charger Installation ${area.city} CA`}
  description={`Professional EV charger installation in ${area.city}, CA from $799. Licensed C-10 contractor. Dedicated circuits, panel upgrades, all brands installed. Permit included.`}
>
  <!-- Hero -->
  <section class="relative overflow-hidden py-20 md:py-24">
    <div class="absolute inset-0 bg-cover bg-center" style="background-image: url('/images/hero-ev-charger.jpg')">
      <div class="absolute inset-0 bg-black/60"></div>
    </div>
    <div class="relative max-w-7xl mx-auto px-4 text-center text-white">
      <p class="text-white/80 text-sm font-semibold uppercase tracking-wider mb-3">EV Charger Installation</p>
      <h1 class="text-4xl md:text-5xl font-extrabold mb-4">
        EV Charger Installation in {area.city}, CA
      </h1>
      <p class="text-2xl font-bold text-accent mb-6">Starting from $799</p>
      <p class="text-white/80 max-w-2xl mx-auto mb-8">
        Licensed C-10 electrical contractor providing professional EV charger installation for homeowners and businesses in {area.city} ({area.zip}).
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/contact/" class="inline-flex items-center justify-center bg-accent hover:bg-accent-dark text-white font-bold px-8 py-4 rounded-lg text-lg transition-colors">
          Get a Free Quote
        </a>
        <a href={`tel:${site.phoneRaw}`} class="inline-flex items-center justify-center border-2 border-white/30 hover:border-white text-white font-bold px-8 py-4 rounded-lg text-lg transition-colors">
          Call {site.phone}
        </a>
      </div>
    </div>
  </section>

  <!-- Services -->
  <section class="py-16">
    <div class="max-w-7xl mx-auto px-4">
      <h2 class="text-2xl font-bold mb-8 text-center">Our Services in {area.city}</h2>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-12">
        {[
          { title: 'EV Charger Installation', price: 'From $799', href: '/services/ev-charger-installation/' },
          { title: 'Panel Upgrade', price: 'From $2,800', href: '/services/electrical-panel-upgrade/' },
          { title: 'Dedicated Circuit', price: 'From $499', href: '/services/dedicated-circuits/' },
          { title: 'Commercial Solutions', price: 'Custom Quote', href: '/services/commercial-ev-solutions/' },
        ].map((svc) => (
          <a href={svc.href} class="block bg-light rounded-xl p-6 hover:shadow-md transition-shadow text-center">
            <h3 class="font-bold mb-2">{svc.title}</h3>
            <p class="text-primary font-semibold">{svc.price}</p>
          </a>
        ))}
      </div>

      <!-- Local content -->
      <div class="max-w-4xl mx-auto">
        <h2 class="text-2xl font-bold mb-4">EV Charger Installation for {area.city} Homes</h2>
        <p class="text-gray leading-relaxed mb-6">
          Fox EV Install provides professional Level 2 EV charger installation for homeowners and businesses in {area.city}. As a licensed C-10 electrical contractor based in the Bay Area, we understand the specific permitting requirements and typical home electrical configurations in {area.city} ({area.zip}).
        </p>
        <p class="text-gray leading-relaxed mb-6">
          Our standard installation includes a site assessment, dedicated 240V circuit, charger mounting, full testing, and city permit with inspection — all starting from $799.
        </p>

        <h3 class="text-xl font-bold mb-4">What We Offer in {area.city}</h3>
        <ul class="space-y-3 mb-8">
          {[
            `Level 2 EV charger installation for ${area.city} homes`,
            'All major brands: Tesla, ChargePoint, Enphase, Grizzl-E, JuiceBox, Autel',
            `${area.city} city permit and inspection included`,
            '100A to 200A and 400A panel upgrades',
            'Dedicated 240V circuits sized for your charger',
            'Free consultation with 24-hour quote',
          ].map((item) => (
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-green-500 shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
              <span class="text-dark">{item}</span>
            </li>
          ))}
        </ul>

        <!-- Why local matters -->
        <h3 class="text-xl font-bold mb-4">Why Choose a Local EV Installer</h3>
        <p class="text-gray leading-relaxed mb-8">
          Permitting requirements vary by city. Our team is familiar with {area.city}'s specific building department procedures, typical inspection timelines, and common home electrical configurations in the area. This local expertise means faster scheduling and first-visit inspection passes.
        </p>

        <!-- Trust -->
        <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
          {[
            { label: '5.0', sub: 'Google Rating' },
            { label: 'C-10', sub: 'Licensed' },
            { label: '3–5 hrs', sub: 'Typical Install' },
            { label: '1 week', sub: 'Scheduling' },
          ].map((stat) => (
            <div class="bg-light rounded-lg p-4 text-center">
              <p class="text-2xl font-bold text-primary">{stat.label}</p>
              <p class="text-xs text-gray">{stat.sub}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <CTA title={`Ready for EV Charging in ${area.city}?`} subtitle="Free quote — most installations scheduled within one week" />
</Base>
