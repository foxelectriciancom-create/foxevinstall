---
import Base from '../layouts/Base.astro';
import Hero from '../components/Hero.astro';
import ServiceCard from '../components/ServiceCard.astro';
import Testimonials from '../components/Testimonials.astro';
import CTA from '../components/CTA.astro';
import { site } from '../data/site';
import { serviceAreas, regions } from '../data/serviceAreas';
---

<Base
  title="Home"
  description="Professional EV charger installation starting from $799. Licensed C-10 contractor serving 29+ Bay Area cities. Panel upgrades, dedicated circuits, residential & commercial."
>
  <Hero
    title="Professional EV Charger Installation"
    subtitle="Bay Area's Trusted EV Charging Experts"
    price="$799"
  />

  <!-- Services Section -->
  <section class="py-16">
    <div class="max-w-7xl mx-auto px-4">
      <h2 class="text-3xl font-bold text-center mb-4">Our Services</h2>
      <p class="text-gray text-center mb-10 max-w-2xl mx-auto">
        From simple charger installations to complete panel upgrades — we handle everything for a safe, code-compliant EV charging setup.
      </p>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
        <ServiceCard
          title="EV Charger Installation"
          description="Level 2 home & business charger installation with permit and inspection included."
          price="From $799"
          href="/services/ev-charger-installation/"
        >
          <svg slot="icon" class="w-10 h-10 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13 10V3L4 14h7v7l9-11h-7z" />
          </svg>
        </ServiceCard>

        <ServiceCard
          title="Electrical Panel Upgrade"
          description="100A to 200A or 400A service upgrades for modern electrical demands."
          price="From $2,800"
          href="/services/electrical-panel-upgrade/"
        >
          <svg slot="icon" class="w-10 h-10 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 3v2m6-2v2M9 19v2m6-2v2M5 9H3m2 6H3m18-6h-2m2 6h-2M7 19h10a2 2 0 002-2V7a2 2 0 00-2-2H7a2 2 0 00-2 2v10a2 2 0 002 2zM9 9h6v6H9V9z" />
          </svg>
        </ServiceCard>

        <ServiceCard
          title="Dedicated Circuits"
          description="240V dedicated circuit with proper breaker sizing for your EV charger."
          price="From $499"
          href="/services/dedicated-circuits/"
        >
          <svg slot="icon" class="w-10 h-10 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707" />
          </svg>
        </ServiceCard>

        <ServiceCard
          title="Commercial EV Solutions"
          description="Multi-charger installations for offices, apartments, and retail locations."
          price="Custom Quote"
          href="/services/commercial-ev-solutions/"
        >
          <svg slot="icon" class="w-10 h-10 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />
          </svg>
        </ServiceCard>
      </div>
    </div>
  </section>

  <!-- Why Choose Us -->
  <section class="py-16 bg-light">
    <div class="max-w-7xl mx-auto px-4">
      <h2 class="text-3xl font-bold text-center mb-10">Why Choose Fox EV Install?</h2>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        <div class="flex gap-4">
          <div class="shrink-0 w-12 h-12 bg-primary/10 rounded-lg flex items-center justify-center">
            <svg class="w-6 h-6 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
            </svg>
          </div>
          <div>
            <h3 class="font-bold mb-1">Licensed & Insured</h3>
            <p class="text-gray text-sm">California C-10 licensed electrical contractor with full liability insurance.</p>
          </div>
        </div>

        <div class="flex gap-4">
          <div class="shrink-0 w-12 h-12 bg-primary/10 rounded-lg flex items-center justify-center">
            <svg class="w-6 h-6 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
            </svg>
          </div>
          <div>
            <h3 class="font-bold mb-1">EV Specialists</h3>
            <p class="text-gray text-sm">Exclusive focus on EV charging infrastructure — not a sideline service.</p>
          </div>
        </div>

        <div class="flex gap-4">
          <div class="shrink-0 w-12 h-12 bg-primary/10 rounded-lg flex items-center justify-center">
            <svg class="w-6 h-6 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4" />
            </svg>
          </div>
          <div>
            <h3 class="font-bold mb-1">Permits Included</h3>
            <p class="text-gray text-sm">We handle all city permits and inspection scheduling at no extra cost.</p>
          </div>
        </div>

        <div class="flex gap-4">
          <div class="shrink-0 w-12 h-12 bg-primary/10 rounded-lg flex items-center justify-center">
            <svg class="w-6 h-6 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          </div>
          <div>
            <h3 class="font-bold mb-1">Fast Scheduling</h3>
            <p class="text-gray text-sm">Most installations scheduled within one week. Same-week appointments often available.</p>
          </div>
        </div>

        <div class="flex gap-4">
          <div class="shrink-0 w-12 h-12 bg-primary/10 rounded-lg flex items-center justify-center">
            <svg class="w-6 h-6 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 9V7a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2m2 4h10a2 2 0 002-2v-6a2 2 0 00-2-2H9a2 2 0 00-2 2v6a2 2 0 002 2zm7-5a2 2 0 11-4 0 2 2 0 014 0z" />
            </svg>
          </div>
          <div>
            <h3 class="font-bold mb-1">Upfront Pricing</h3>
            <p class="text-gray text-sm">Clear, written quotes with no hidden fees. Know your total cost before we start.</p>
          </div>
        </div>

        <div class="flex gap-4">
          <div class="shrink-0 w-12 h-12 bg-primary/10 rounded-lg flex items-center justify-center">
            <svg class="w-6 h-6 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z" />
            </svg>
          </div>
          <div>
            <h3 class="font-bold mb-1">5.0 Rating</h3>
            <p class="text-gray text-sm">Perfect score across Google, Facebook, and Yelp from {site.reviewCount} verified reviews.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <Testimonials />

  <!-- Service Areas -->
  <section class="py-16">
    <div class="max-w-7xl mx-auto px-4">
      <h2 class="text-3xl font-bold text-center mb-4">Service Areas</h2>
      <p class="text-gray text-center mb-10">Serving {site.citiesServed} cities across the San Francisco Bay Area</p>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {Object.entries(regions).map(([key, label]) => (
          <div>
            <h3 class="font-bold text-lg mb-3">{label}</h3>
            <ul class="space-y-1.5">
              {serviceAreas
                .filter((a) => a.region === key)
                .map((area) => (
                  <li>
                    <a
                      href={`/service-areas/ev-charger-installation-${area.slug}/`}
                      class="text-sm text-gray hover:text-primary transition-colors"
                    >
                      {area.city}
                    </a>
                  </li>
                ))}
            </ul>
          </div>
        ))}
      </div>

      <div class="text-center mt-8">
        <a href="/service-areas/" class="text-primary font-semibold hover:underline">
          View all service areas →
        </a>
      </div>
    </div>
  </section>

  <CTA />
</Base>
