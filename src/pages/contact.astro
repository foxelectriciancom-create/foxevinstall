---
import Base from '../layouts/Base.astro';
import PageHero from '../components/PageHero.astro';
import { site } from '../data/site';
---

<Base
  title="Contact Fox EV Install | Free EV Charger Installation Quote"
  description="Get a free EV charger installation quote. Call (650) 550-0619 or fill out our form. Response within 2 hours during business hours."
>
  <PageHero
    title="Contact Us"
    subtitle="Get a free quote for your EV charger installation. We respond to all inquiries within 2 hours during business hours."
  />

  <section class="py-16">
    <div class="max-w-7xl mx-auto px-4 grid grid-cols-1 lg:grid-cols-2 gap-12">
      <div>
        <h2 class="text-2xl font-bold mb-2">Request a Free Quote</h2>
        <p class="text-gray mb-6">Fill out the form below and we'll get back to you with a detailed estimate.</p>
        <form action="https://formspree.io/f/YOUR_FORM_ID" method="POST" class="space-y-5">
          <div>
            <label class="block text-sm font-medium text-dark mb-1">Name *</label>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
              <div>
                <input type="text" name="first_name" required placeholder="First"
                  class="w-full px-4 py-3 border border-gray-200 rounded-lg focus:ring-2 focus:ring-primary focus:border-transparent" />
              </div>
              <div>
                <input type="text" name="last_name" required placeholder="Last"
                  class="w-full px-4 py-3 border border-gray-200 rounded-lg focus:ring-2 focus:ring-primary focus:border-transparent" />
              </div>
            </div>
          </div>
          <div>
            <label for="email" class="block text-sm font-medium text-dark mb-1">Email *</label>
            <input type="email" id="email" name="email" required
              class="w-full px-4 py-3 border border-gray-200 rounded-lg focus:ring-2 focus:ring-primary focus:border-transparent" />
          </div>
          <div>
            <label for="message" class="block text-sm font-medium text-dark mb-1">Comment or Message</label>
            <textarea id="message" name="message" rows="4"
              class="w-full px-4 py-3 border border-gray-200 rounded-lg focus:ring-2 focus:ring-primary focus:border-transparent"
              placeholder="Tell us about your project..."></textarea>
          </div>
          <button type="submit"
            class="bg-primary hover:bg-primary-dark text-white font-bold px-8 py-3.5 rounded-lg transition-colors">
            Submit
          </button>
        </form>
      </div>

      <div>
        <h2 class="text-2xl font-bold mb-6">Get in Touch</h2>
        <div class="space-y-4">
          <div class="bg-light rounded-xl p-5 flex items-center gap-4">
            <div class="shrink-0 w-10 h-10 bg-primary/10 rounded-full flex items-center justify-center">
              <svg class="w-5 h-5 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
              </svg>
            </div>
            <div>
              <p class="font-bold text-dark text-sm">Phone</p>
              <a href={`tel:${site.phoneRaw}`} class="text-primary font-semibold hover:underline">{site.phone}</a>
            </div>
          </div>

          <div class="bg-light rounded-xl p-5 flex items-center gap-4">
            <div class="shrink-0 w-10 h-10 bg-primary/10 rounded-full flex items-center justify-center">
              <svg class="w-5 h-5 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
              </svg>
            </div>
            <div>
              <p class="font-bold text-dark text-sm">Email</p>
              <a href={`mailto:${site.email}`} class="text-primary font-semibold hover:underline">{site.email}</a>
            </div>
          </div>

          <div class="bg-light rounded-xl p-5 flex items-center gap-4">
            <div class="shrink-0 w-10 h-10 bg-primary/10 rounded-full flex items-center justify-center">
              <svg class="w-5 h-5 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
              </svg>
            </div>
            <div>
              <p class="font-bold text-dark text-sm">Service Area</p>
              <p class="text-gray text-sm">San Francisco Bay Area — Peninsula, South Bay & surrounding cities</p>
            </div>
          </div>

          <div class="bg-light rounded-xl p-5 flex items-center gap-4">
            <div class="shrink-0 w-10 h-10 bg-primary/10 rounded-full flex items-center justify-center">
              <svg class="w-5 h-5 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
              </svg>
            </div>
            <div>
              <p class="font-bold text-dark text-sm">Response Time</p>
              <p class="text-gray text-sm">We respond within 2 hours during business hours. Emergency calls answered 24/7.</p>
            </div>
          </div>

          <div class="bg-white border border-gray-200 rounded-xl p-5">
            <p class="font-bold text-dark mb-3">Business Hours</p>
            <div class="space-y-2 text-sm">
              <div class="flex justify-between"><span class="text-gray">Monday – Friday</span><span class="font-semibold text-dark">7:00 AM – 6:00 PM</span></div>
              <div class="flex justify-between"><span class="text-gray">Saturday</span><span class="font-semibold text-dark">8:00 AM – 4:00 PM</span></div>
              <div class="flex justify-between"><span class="text-gray">Sunday</span><span class="font-semibold text-dark">Closed</span></div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="py-5 bg-light">
    <div class="max-w-7xl mx-auto px-4 text-center">
      <p class="text-gray">We serve 30+ cities across the Bay Area. <a href="/service-areas/" class="text-primary font-semibold hover:underline">View all service areas &rarr;</a></p>
    </div>
  </section>

  <section class="py-16 bg-primary text-white">
    <div class="max-w-4xl mx-auto px-4 text-center">
      <h2 class="text-3xl font-bold mb-4">Prefer to Call?</h2>
      <p class="text-white/70 text-lg mb-8">Speak directly with a licensed electrician. No call centers, no voicemail maze — just a real person who can answer your questions.</p>
      <a href={`tel:${site.phoneRaw}`}
        class="inline-flex items-center justify-center bg-accent hover:bg-accent-dark text-white font-bold px-8 py-4 rounded-lg text-lg transition-colors">
        Call {site.phone}
      </a>
    </div>
  </section>
</Base>
