---
import Base from '../layouts/Base.astro';
import { site } from '../data/site';
---

<Base
  title="Contact Us"
  description="Get a free EV charger installation quote. Call (650) 550-0619 or fill out our form. Response within 2 hours during business hours."
>
  <section class="py-16 bg-gradient-to-br from-primary-dark via-primary to-primary-light text-white">
    <div class="max-w-7xl mx-auto px-4 text-center">
      <h1 class="text-4xl md:text-5xl font-extrabold mb-4">Contact Us</h1>
      <p class="text-white/80 text-lg">Get a free quote — response within 2 hours during business hours</p>
    </div>
  </section>

  <section class="py-16">
    <div class="max-w-7xl mx-auto px-4 grid grid-cols-1 lg:grid-cols-2 gap-12">
      <!-- Contact Form -->
      <div>
        <h2 class="text-2xl font-bold mb-6">Get a Free Quote</h2>
        <form action="https://formspree.io/f/YOUR_FORM_ID" method="POST" class="space-y-5">
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div>
              <label for="first-name" class="block text-sm font-medium text-dark mb-1">First Name</label>
              <input type="text" id="first-name" name="first_name" required
                class="w-full px-4 py-3 border border-gray-200 rounded-lg focus:ring-2 focus:ring-primary focus:border-transparent" />
            </div>
            <div>
              <label for="last-name" class="block text-sm font-medium text-dark mb-1">Last Name</label>
              <input type="text" id="last-name" name="last_name" required
                class="w-full px-4 py-3 border border-gray-200 rounded-lg focus:ring-2 focus:ring-primary focus:border-transparent" />
            </div>
          </div>
          <div>
            <label for="email" class="block text-sm font-medium text-dark mb-1">Email</label>
            <input type="email" id="email" name="email" required
              class="w-full px-4 py-3 border border-gray-200 rounded-lg focus:ring-2 focus:ring-primary focus:border-transparent" />
          </div>
          <div>
            <label for="phone" class="block text-sm font-medium text-dark mb-1">Phone (optional)</label>
            <input type="tel" id="phone" name="phone"
              class="w-full px-4 py-3 border border-gray-200 rounded-lg focus:ring-2 focus:ring-primary focus:border-transparent" />
          </div>
          <div>
            <label for="service" class="block text-sm font-medium text-dark mb-1">Service Needed</label>
            <select id="service" name="service"
              class="w-full px-4 py-3 border border-gray-200 rounded-lg focus:ring-2 focus:ring-primary focus:border-transparent">
              <option value="">Select a service...</option>
              <option value="ev-charger">EV Charger Installation</option>
              <option value="panel-upgrade">Electrical Panel Upgrade</option>
              <option value="dedicated-circuit">Dedicated Circuit</option>
              <option value="commercial">Commercial EV Solutions</option>
              <option value="other">Other</option>
            </select>
          </div>
          <div>
            <label for="message" class="block text-sm font-medium text-dark mb-1">Message</label>
            <textarea id="message" name="message" rows="4"
              class="w-full px-4 py-3 border border-gray-200 rounded-lg focus:ring-2 focus:ring-primary focus:border-transparent"
              placeholder="Tell us about your project..."></textarea>
          </div>
          <button type="submit"
            class="w-full bg-accent hover:bg-accent-dark text-white font-bold py-4 rounded-lg transition-colors text-lg">
            Send Message
          </button>
        </form>
      </div>

      <!-- Contact Info -->
      <div>
        <h2 class="text-2xl font-bold mb-6">Contact Information</h2>
        <div class="space-y-6">
          <div class="flex items-start gap-4">
            <div class="shrink-0 w-12 h-12 bg-primary/10 rounded-lg flex items-center justify-center">
              <svg class="w-6 h-6 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
              </svg>
            </div>
            <div>
              <h3 class="font-bold mb-1">Phone</h3>
              <a href={`tel:${site.phoneRaw}`} class="text-primary text-lg font-semibold hover:underline">{site.phone}</a>
              <p class="text-gray text-sm mt-1">Direct line to licensed electricians — no call centers</p>
            </div>
          </div>

          <div class="flex items-start gap-4">
            <div class="shrink-0 w-12 h-12 bg-primary/10 rounded-lg flex items-center justify-center">
              <svg class="w-6 h-6 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
              </svg>
            </div>
            <div>
              <h3 class="font-bold mb-1">Email</h3>
              <a href={`mailto:${site.email}`} class="text-primary font-semibold hover:underline">{site.email}</a>
            </div>
          </div>

          <div class="flex items-start gap-4">
            <div class="shrink-0 w-12 h-12 bg-primary/10 rounded-lg flex items-center justify-center">
              <svg class="w-6 h-6 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            </div>
            <div>
              <h3 class="font-bold mb-1">Business Hours</h3>
              <p class="text-dark">Monday – Friday: 7:00 AM – 6:00 PM</p>
              <p class="text-dark">Saturday: 8:00 AM – 4:00 PM</p>
              <p class="text-dark">Sunday: Closed</p>
              <p class="text-primary font-medium mt-1">Emergency calls: Available 24/7</p>
            </div>
          </div>

          <div class="flex items-start gap-4">
            <div class="shrink-0 w-12 h-12 bg-primary/10 rounded-lg flex items-center justify-center">
              <svg class="w-6 h-6 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
              </svg>
            </div>
            <div>
              <h3 class="font-bold mb-1">Service Area</h3>
              <p class="text-dark">San Francisco Bay Area</p>
              <p class="text-gray text-sm">Peninsula, South Bay, and surrounding cities ({site.citiesServed} cities)</p>
            </div>
          </div>
        </div>

        <!-- Response time -->
        <div class="mt-8 bg-green-50 border border-green-200 rounded-xl p-5">
          <p class="text-green-800 font-medium">Response within 2 hours during business hours</p>
          <p class="text-green-700 text-sm mt-1">Every consultation and estimate is free — no obligation, no pressure.</p>
        </div>
      </div>
    </div>
  </section>
</Base>
