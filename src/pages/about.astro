---
import Base from '../layouts/Base.astro';
import PageHero from '../components/PageHero.astro';
import CTA from '../components/CTA.astro';
import { site } from '../data/site';
---

<Base
  title="About Fox EV Install | Licensed Bay Area Electrician"
  description="Licensed C-10 electrical contractor specializing in EV charger installation. Bay Area's dedicated EV charging experts serving 29+ cities."
>
  <PageHero
    title="Meet Our Team"
    label="Leadership"
    image="/images/hero-home-ev.webp"
  />

  <section class="py-16">
    <div class="max-w-6xl mx-auto px-4">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-10 items-start">
        <div class="md:col-span-1">
          <div class="bg-dark rounded-xl overflow-hidden aspect-[3/4] flex items-end p-6">
            <div class="text-white">
              <p class="font-bold text-lg">Fox EV Install</p>
              <p class="text-white/70 text-sm">Licensed C-10 Electricians</p>
            </div>
          </div>
        </div>
        <div class="md:col-span-2 space-y-5 text-gray leading-relaxed">
          <p>Fox EV Install was founded to solve a simple problem: Bay Area homeowners buying electric vehicles couldn't find electricians who truly understood EV charging infrastructure.</p>
          <p>General electricians often over-quote the work, use incorrect wire sizing, or don't understand the specific requirements of different charger brands. We built our entire company around this one specialty — and it shows in the quality and efficiency of our work.</p>
          <p>Every installation starts with a thorough assessment of your electrical system. Not a quick glance at your panel, but a proper load calculation, wire run measurement, and evaluation of your home's electrical capacity. We provide detailed, written quotes with no hidden fees. The price we quote is the price you pay.</p>
          <p>We pull permits for every job, even when customers say they don't need one. California requires permits for EV charger installations, and cutting corners on permitting can create problems when you sell your home, file an insurance claim, or apply for utility rebates. We handle the entire permit process — you don't have to deal with the city at all.</p>
          <p>Our focus on EV charging means we've seen every possible installation scenario — from 1960s Eichler homes in Palo Alto to new construction in San Jose, from attached garages with panels nearby to detached garages requiring 100+ foot wire runs. We handle it all.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="py-16 bg-light">
    <div class="max-w-6xl mx-auto px-4">
      <h2 class="text-3xl font-bold text-center mb-10">What Makes Us Different</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {[
          { title: 'EV charging specialists', desc: "We don't install ceiling fans or rewire kitchens. EV charging is all we do — this deep focus means faster, better installations.", icon: `<svg class="w-7 h-7 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" /></svg>` },
          { title: 'Full permit support', desc: "City permit submissions, PG&E coordination, and inspections all handled — you don't deal with the city at all.", icon: `<svg class="w-7 h-7 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4" /></svg>` },
          { title: 'Panel & infrastructure experts', desc: '200A/400A upgrades, dedicated circuits, load calculations, and proper wire sizing for any home or business.', icon: `<svg class="w-7 h-7 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.066 2.573c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.573 1.066c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.066-2.573c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" /></svg>` },
          { title: 'Residential & commercial', desc: 'Single-family homes, apartments, condos, offices, and retail — we handle every property type in the Bay Area.', icon: `<svg class="w-7 h-7 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" /></svg>` },
          { title: 'Local Bay Area team', desc: `Based in San Carlos, serving ${site.citiesServed} cities. Same-week scheduling and fast response across the Peninsula and South Bay.`, icon: `<svg class="w-7 h-7 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" /></svg>` },
        ].map((item) => (
          <div class="bg-white rounded-xl p-6 shadow-sm">
            <div class="mb-3"><Fragment set:html={item.icon} /></div>
            <h3 class="font-bold text-dark mb-2">{item.title}</h3>
            <p class="text-gray text-sm leading-relaxed">{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="py-16">
    <div class="max-w-4xl mx-auto px-4">
      <h2 class="text-3xl font-bold mb-6">Our Mission</h2>
      <p class="text-gray text-lg leading-relaxed mb-8">
        To make EV charging accessible to every Bay Area homeowner and business — through honest pricing, expert installation, and a commitment to doing every job right the first time.
      </p>
      <div class="flex flex-wrap gap-3">
        {[
          { icon: `<svg class="w-4 h-4 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" /></svg>`, text: 'California C-10 Licensed Contractor' },
          { icon: `<svg class="w-4 h-4 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>`, text: 'Fully Insured' },
          { icon: `<svg class="w-4 h-4 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" /></svg>`, text: 'EV Charging Specialists' },
          { icon: `<svg class="w-4 h-4 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4" /></svg>`, text: 'Permit & Inspection Included' },
          { icon: `<svg class="w-4 h-4 text-amber-400" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" /></svg>`, text: '5.0 Google Rating' },
        ].map((badge) => (
          <span class="inline-flex items-center gap-2 bg-light border border-gray-200 rounded-full px-4 py-2 text-sm font-medium text-dark">
            <Fragment set:html={badge.icon} /> {badge.text}
          </span>
        ))}
      </div>
    </div>
  </section>

  <CTA title="Schedule Service" subtitle="Get a free consultation for your EV charging project" />
</Base>
