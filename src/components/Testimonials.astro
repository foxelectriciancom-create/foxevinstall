---
const reviews = [
  { name: 'Michael T.', city: 'San Carlos', text: 'Excellent work installing our Tesla Wall Connector. Professional, clean, and done in under 4 hours. Highly recommend!' },
  { name: 'Sarah L.', city: 'Palo Alto', text: 'They handled everything — permit, installation, inspection. The panel upgrade was seamless and now we charge two EVs at home.' },
  { name: 'David K.', city: 'Mountain View', text: 'Fair pricing, great communication, and quality work. Our ChargePoint was installed exactly where we wanted it.' },
  { name: 'Jennifer W.', city: 'San Mateo', text: 'Fast turnaround — called on Monday, installed by Thursday. Very knowledgeable about EV charging options.' },
  { name: 'Robert M.', city: 'Redwood City', text: 'Panel upgrade from 100A to 200A plus EV charger install. Clean work, passed inspection first try.' },
  { name: 'Lisa H.', city: 'Burlingame', text: 'The team was punctual, professional, and left our garage cleaner than they found it. Five stars!' },
];
---

<section class="py-16 bg-light">
  <div class="max-w-7xl mx-auto px-4">
    <h2 class="text-3xl font-bold text-center mb-4">What Our Customers Say</h2>
    <p class="text-gray text-center mb-10">5.0 average rating across Google, Facebook, and Yelp</p>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {reviews.map((review) => (
        <div class="bg-white rounded-xl p-6 shadow-sm">
          <div class="flex gap-1 mb-3">
            {[...Array(5)].map(() => (
              <svg class="w-5 h-5 text-accent" fill="currentColor" viewBox="0 0 20 20">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
              </svg>
            ))}
          </div>
          <p class="text-dark text-sm leading-relaxed mb-4">"{review.text}"</p>
          <p class="text-gray text-sm font-medium">— {review.name}, {review.city}</p>
        </div>
      ))}
    </div>
  </div>
</section>
