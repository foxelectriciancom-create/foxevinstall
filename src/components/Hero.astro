---
import { site } from '../data/site';

interface Props {
  title: string;
  subtitle?: string;
  price?: string;
  cta?: string;
  ctaHref?: string;
}

const { title, subtitle, price, cta = 'Get a Free Quote', ctaHref = '/contact/' } = Astro.props;
---

<section class="relative bg-gradient-to-br from-primary-dark via-primary to-primary-light text-white py-20 md:py-28">
  <div class="absolute inset-0 bg-[url('/images/hero-pattern.svg')] opacity-10"></div>
  <div class="relative max-w-7xl mx-auto px-4 text-center">
    {subtitle && <p class="text-primary-light/80 text-sm font-semibold uppercase tracking-wider mb-3">{subtitle}</p>}
    <h1 class="text-4xl md:text-5xl lg:text-6xl font-extrabold leading-tight mb-6">{title}</h1>
    {price && (
      <p class="text-2xl md:text-3xl font-bold text-accent mb-8">
        Starting from {price}
      </p>
    )}
    <div class="flex flex-col sm:flex-row gap-4 justify-center">
      <a
        href={ctaHref}
        class="inline-flex items-center justify-center bg-accent hover:bg-accent-dark text-white font-bold px-8 py-4 rounded-lg text-lg transition-colors"
      >
        {cta}
      </a>
      <a
        href={`tel:${site.phoneRaw}`}
        class="inline-flex items-center justify-center border-2 border-white/30 hover:border-white text-white font-bold px-8 py-4 rounded-lg text-lg transition-colors"
      >
        Call {site.phone}
      </a>
    </div>
    <div class="mt-10 flex flex-wrap justify-center gap-6 text-sm text-white/80">
      <span class="flex items-center gap-1.5">
        <svg class="w-5 h-5 text-accent" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
        5.0 Rating
      </span>
      <span>{site.license}</span>
      <span>{site.citiesServed} Cities Served</span>
    </div>
  </div>
</section>
