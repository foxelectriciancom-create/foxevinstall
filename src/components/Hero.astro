---
import { site } from '../data/site';

interface Props {
  title: string;
  subtitle?: string;
  price?: string;
  cta?: string;
  ctaHref?: string;
}

const { title, subtitle, price, cta = 'Schedule Service', ctaHref = '/contact/' } = Astro.props;

const slides = [
  {
    image: '/images/hero-ev-charger.webp',
    heading: 'EV Charger Installation from $799',
    text: 'Professional Level 2 home and commercial EV charger installation. All major brands supported with permit and inspection included.',
  },
  {
    image: '/images/hero-panel.webp',
    heading: 'Electrical Panel Upgrades from $2,800',
    text: 'Upgrade to a modern, safe electrical panel and power your EV charger, home appliances, and future electric needs. Full permitting included.',
  },
  {
    image: '/images/hero-circuit.webp',
    heading: 'Dedicated 240V Circuits from $499',
    text: 'Professional 240V dedicated circuit installation for EV chargers, hot tubs, and high-power appliances. Proper breaker and wire sizing guaranteed.',
  },
  {
    image: '/images/hero-home-ev.webp',
    heading: 'Residential & Commercial Solutions',
    text: 'From single-family homes to apartment complexes and office buildings. Custom EV charging infrastructure designed for your needs.',
  },
];
---

<section class="relative overflow-hidden">
  <!-- Slider container -->
  <div id="hero-slider" class="relative h-[520px] md:h-[600px]">
    {slides.map((slide, i) => (
      <div
        class:list={['hero-slide absolute inset-0 transition-opacity duration-700', i === 0 ? 'opacity-100 z-10' : 'opacity-0 z-0']}
        data-index={i}
      >
        <div class="absolute inset-0">
          <img
            src={slide.image}
            alt={slide.heading}
            class="w-full h-full object-cover"
            loading={i === 0 ? 'eager' : 'lazy'}
            fetchpriority={i === 0 ? 'high' : 'low'}
          />
          <div class="absolute inset-0 bg-black/50"></div>
        </div>
        <div class="relative h-full flex items-center">
          <div class="max-w-7xl mx-auto px-4 md:px-8 w-full">
            <div class="max-w-xl text-white">
              <h2 class="text-3xl md:text-4xl lg:text-5xl font-extrabold leading-tight mb-4">
                {slide.heading}
              </h2>
              <p class="text-white/80 text-base md:text-lg mb-6 leading-relaxed">
                {slide.text}
              </p>
              <a
                href={ctaHref}
                class="inline-flex items-center bg-primary hover:bg-primary-dark text-white font-bold px-7 py-3.5 rounded-lg text-base transition-colors"
              >
                {cta}
                <svg class="w-5 h-5 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                </svg>
              </a>
            </div>
          </div>
        </div>
      </div>
    ))}

    <!-- Trust badges overlay -->
    <div class="absolute bottom-6 left-0 right-0 z-20">
      <div class="max-w-7xl mx-auto px-4 md:px-8">
        <div class="flex flex-wrap gap-6 text-white/80 text-sm">
          <span class="flex items-center gap-2">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" /></svg>
            Licensed & Insured
          </span>
          <span class="flex items-center gap-2">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20"><path d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z"/></svg>
            100% Satisfaction
          </span>
          <span class="flex items-center gap-2">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
            24/7 Available
          </span>
        </div>
      </div>
    </div>

    <!-- Slider dots -->
    <div class="absolute bottom-6 right-8 z-20 flex gap-2.5">
      {slides.map((_, i) => (
        <button
          class:list={['hero-dot w-3 h-3 rounded-full transition-colors', i === 0 ? 'bg-primary' : 'bg-white/50']}
          data-index={i}
          aria-label={`Slide ${i + 1}`}
        />
      ))}
    </div>
  </div>

  <!-- Rating bar -->
  <div class="bg-white border-b py-5">
    <div class="max-w-7xl mx-auto px-4 flex flex-wrap items-center justify-center gap-8 md:gap-12">
      <div class="flex items-center gap-3">
        <span class="text-4xl md:text-5xl font-extrabold text-dark">5.0</span>
        <div class="text-sm text-gray leading-tight">
          <div>Average Trust Rating</div>
          <div>Among Our Customers</div>
        </div>
      </div>

      <div class="flex items-center gap-2">
        <span class="font-semibold text-dark">Google</span>
        <svg class="w-6 h-6" viewBox="0 0 24 24"><path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 01-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z" fill="#4285F4"/><path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/><path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/><path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/></svg>
        <div class="flex gap-0.5">
          {[...Array(5)].map(() => (
            <svg class="w-4 h-4 text-amber-400" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
          ))}
        </div>
      </div>

      <div class="flex items-center gap-2">
        <span class="font-semibold text-dark">Facebook</span>
        <svg class="w-6 h-6" viewBox="0 0 24 24"><circle cx="12" cy="12" r="12" fill="#1877F2"/><path d="M16.67 15.47l.53-3.47h-3.33V9.87c0-.95.46-1.87 1.95-1.87h1.51V5.08S15.98 4.8 14.7 4.8c-2.7 0-4.47 1.63-4.47 4.59V12H7.13v3.47h3.1V24h3.64V15.47h2.8z" fill="white"/></svg>
        <div class="flex gap-0.5">
          {[...Array(5)].map(() => (
            <svg class="w-4 h-4 text-amber-400" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
          ))}
        </div>
      </div>

      <div class="flex items-center gap-2">
        <span class="font-semibold text-dark">Yelp</span>
        <svg class="w-6 h-6" viewBox="0 0 24 24"><rect width="24" height="24" rx="4" fill="#D32323"/><path d="M12.6 15.7l2.4 1.6c.3.2.1.7-.3.7h-2.9c-.3 0-.4-.3-.3-.5l.8-1.6c.1-.2.2-.3.3-.2zm-1.4-1.1l-1.6-2.4c-.2-.3.1-.6.4-.6h2.1c.3 0 .5.2.4.5l-.9 2.3c-.1.3-.3.3-.4.2zm-2.8-3.9l.3-2.9c0-.4.5-.4.7-.2l1.9 1.9c.2.2.1.5-.2.6l-2.2.9c-.3.1-.5-.1-.5-.3zm1.8-5.5l1.3 2.6c.1.3-.1.5-.3.5l-2.3-.2c-.3 0-.4-.3-.3-.5l1.1-2.2c.2-.3.4-.3.5-.2zm5.4 3.3l-2.7.8c-.3.1-.5-.1-.5-.4l.5-2.2c.1-.3.3-.4.5-.3l2.1 1.5c.3.2.3.5.1.6z" fill="white"/></svg>
        <div class="flex gap-0.5">
          {[...Array(5)].map(() => (
            <svg class="w-4 h-4 text-amber-400" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  const slides = document.querySelectorAll('.hero-slide');
  const dots = document.querySelectorAll('.hero-dot');
  let current = 0;
  const total = slides.length;

  function goTo(index: number) {
    slides[current].classList.remove('opacity-100', 'z-10');
    slides[current].classList.add('opacity-0', 'z-0');
    dots[current].classList.remove('bg-primary');
    dots[current].classList.add('bg-white/50');

    current = index;

    slides[current].classList.remove('opacity-0', 'z-0');
    slides[current].classList.add('opacity-100', 'z-10');
    dots[current].classList.remove('bg-white/50');
    dots[current].classList.add('bg-primary');
  }

  dots.forEach((dot) => {
    dot.addEventListener('click', () => {
      goTo(Number((dot as HTMLElement).dataset.index));
    });
  });

  setInterval(() => {
    goTo((current + 1) % total);
  }, 6000);
</script>
