---
import { site, nav } from '../data/site';
---

<header class="sticky top-0 z-50 bg-white shadow-sm">
  <!-- Top bar -->
  <div class="bg-primary text-white text-sm py-2">
    <div class="max-w-7xl mx-auto px-4 flex justify-between items-center">
      <span class="hidden sm:inline">{site.license}</span>
      <div class="flex items-center gap-4">
        <a href={`tel:${site.phoneRaw}`} class="hover:text-accent transition-colors">
          {site.phone}
        </a>
        <span class="hidden md:inline">{site.hours.weekday} | {site.hours.saturday}</span>
      </div>
    </div>
  </div>

  <!-- Main nav -->
  <nav class="max-w-7xl mx-auto px-4 py-4 flex items-center justify-between">
    <a href="/" class="flex items-center gap-2">
      <span class="text-2xl font-bold text-primary">Fox</span>
      <span class="text-2xl font-bold text-dark">EV Install</span>
    </a>

    <!-- Desktop menu -->
    <ul class="hidden lg:flex items-center gap-6">
      {nav.map((item) => (
        <li class="relative group">
          <a
            href={item.href}
            class="text-dark hover:text-primary font-medium transition-colors py-2"
          >
            {item.label}
            {'children' in item && (
              <svg class="inline w-4 h-4 ml-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
              </svg>
            )}
          </a>
          {'children' in item && (
            <ul class="absolute top-full left-0 bg-white shadow-lg rounded-lg py-2 min-w-[220px] opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all">
              {item.children.map((child) => (
                <li>
                  <a href={child.href} class="block px-4 py-2 text-sm text-dark hover:bg-light hover:text-primary transition-colors">
                    {child.label}
                  </a>
                </li>
              ))}
            </ul>
          )}
        </li>
      ))}
    </ul>

    <!-- CTA button -->
    <a
      href="/contact/"
      class="hidden lg:inline-flex bg-accent hover:bg-accent-dark text-white font-semibold px-5 py-2.5 rounded-lg transition-colors"
    >
      Get Free Quote
    </a>

    <!-- Mobile menu button -->
    <button
      id="mobile-menu-btn"
      class="lg:hidden p-2 text-dark"
      aria-label="Toggle menu"
    >
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
    </button>
  </nav>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="hidden lg:hidden bg-white border-t">
    <div class="px-4 py-4 space-y-2">
      {nav.map((item) => (
        <a href={item.href} class="block py-2 text-dark hover:text-primary font-medium">
          {item.label}
        </a>
      ))}
      <a
        href="/contact/"
        class="block mt-4 bg-accent text-white text-center font-semibold px-5 py-3 rounded-lg"
      >
        Get Free Quote
      </a>
    </div>
  </div>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  btn?.addEventListener('click', () => {
    menu?.classList.toggle('hidden');
  });
</script>
