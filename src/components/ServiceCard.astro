---
interface Props {
  title: string;
  description: string;
  price: string;
  href: string;
  icon?: string;
}

const { title, description, price, href } = Astro.props;
---

<a href={href} class="group block bg-white rounded-xl shadow-md hover:shadow-xl p-6 transition-all hover:-translate-y-1">
  <div class="mb-4">
    <slot name="icon" />
  </div>
  <h3 class="text-lg font-bold text-dark group-hover:text-primary transition-colors mb-2">{title}</h3>
  <p class="text-gray text-sm leading-relaxed mb-4">{description}</p>
  <p class="text-primary font-bold text-lg">{price}</p>
</a>
